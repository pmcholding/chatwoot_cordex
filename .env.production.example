# ========================================
# CONFIGURAÇÃO DE PRODUÇÃO - CHATWOOT CORDEX
# ========================================

# ============ CONFIGURAÇÕES BÁSICAS ============
RAILS_ENV=production
SECRET_KEY_BASE=SUBSTITUA_POR_UMA_CHAVE_SEGURA_DE_64_CARACTERES
FRONTEND_URL=https://seu-dominio.com

# ============ BANCO DE DADOS ============
POSTGRES_HOST=seu-postgres-host
POSTGRES_USERNAME=chatwoot_user
POSTGRES_PASSWORD=sua_senha_segura
POSTGRES_DATABASE=chatwoot_production
POSTGRES_PORT=5432

# ============ REDIS ============
REDIS_URL=redis://seu-redis-host:6379
REDIS_PASSWORD=sua_senha_redis

# ============ STRIPE (OBRIGATÓRIO) ============
# Chaves de produção do Stripe
STRIPE_SECRET_KEY=sk_live_SUA_CHAVE_SECRETA_AQUI
STRIPE_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET_AQUI

# ============ EMAIL SMTP ============
MAILER_SENDER_EMAIL=noreply@seu-dominio.com
SMTP_ADDRESS=seu-servidor-smtp.com
SMTP_PORT=587
SMTP_USERNAME=seu-usuario-smtp
SMTP_PASSWORD=sua-senha-smtp
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_DOMAIN=seu-dominio.com

# ============ SEGURANÇA ============
FORCE_SSL=true
RAILS_LOG_TO_STDOUT=true
RAILS_MAX_THREADS=5

# ============ PERFORMANCE ============
SIDEKIQ_CONCURRENCY=10

# ============ ARMAZENAMENTO (OPCIONAL) ============
# Para upload de arquivos na AWS S3
# AWS_ACCESS_KEY_ID=sua_chave_aws
# AWS_SECRET_ACCESS_KEY=sua_chave_secreta_aws
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=seu-bucket
# DIRECT_UPLOADS_ENABLED=true

# ============ NOTIFICAÇÕES PUSH (OPCIONAL) ============
# VAPID_PUBLIC_KEY=sua_chave_publica_vapid
# VAPID_PRIVATE_KEY=sua_chave_privada_vapid
# FCM_SERVER_KEY=sua_chave_fcm

# ============ INTEGRAÇÕES IA (OPCIONAL) ============
# OPENAI_API_KEY=sua_chave_openai

# ============ MICROSOFT AZURE (OPCIONAL) ============
# AZURE_APP_ID=seu_app_id_azure
# AZURE_APP_SECRET=seu_app_secret_azure

# ============ CAPTCHA (OPCIONAL) ============
# HCAPTCHA_SITE_KEY=sua_chave_site_hcaptcha
# HCAPTCHA_SECRET_KEY=sua_chave_secreta_hcaptcha

# ============ CONFIGURAÇÕES AVANÇADAS ============
# Timeout do banco de dados
POSTGRES_STATEMENT_TIMEOUT=14s

# SSL para Redis (se necessário)
REDIS_OPENSSL_VERIFY_MODE=none

# ============ MONITORAMENTO (OPCIONAL) ============
# SENTRY_DSN=sua_dsn_sentry
# NEW_RELIC_LICENSE_KEY=sua_chave_newrelic

# ============ CONFIGURAÇÕES ESPECÍFICAS CORDEX ============
# Estas configurações já estão habilitadas na imagem:
# - captain_integration (Agente IA)
# - whatsapp_campaign (Campanhas WhatsApp)
# - whatsapp_embedded_signup (Cadastro WhatsApp)
# - shopify_integration (Integração Shopify)
# - sla (Acordos de Nível de Serviço)
# - disable_branding (Remover Branding)
# - custom_roles (Funções Personalizadas)

# ============ INSTALAÇÃO ============
INSTALLATION_NAME=Cordex
DEPLOYMENT_ENV=self-hosted
